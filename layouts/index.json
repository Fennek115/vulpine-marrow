{{- /* Índice de búsqueda full-text generado en build. Lo consume js/search.js
       (fetch a /index.json) para el buscador client-side, sin CDN ni dependencias.
       Sólo el BLOG: se excluye el Códice del Polvo (es un libro aparte) igual que
       en el índice del blog (_default/list.html), y las páginas con `noindex`. */ -}}
{{- $all := where .Site.RegularPages "Type" "posts" -}}
{{- $codice := where $all "Params.series" "intersect" (slice "Códice del Polvo") -}}
{{- $blog := complement $codice $all -}}
{{- $idx := slice -}}
{{- range where $blog "Params.noindex" "!=" true -}}
  {{- $entry := dict
      "title" .Title
      "url" .RelPermalink
      "date" (.Date.Format "2006-01-02")
      "section" .Section
      "series" (index (.Params.series | default slice) 0)
      "summary" (partial "wikilinks-plain.html" (.Summary | plainify | htmlUnescape))
      "tags" (.Params.tags | default slice)
      "content" (substr (partial "wikilinks-plain.html" (.Plain | htmlUnescape)) 0 8000)
  -}}
  {{- $idx = $idx | append $entry -}}
{{- end -}}
{{- $idx | jsonify -}}
